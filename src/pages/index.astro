---
// Página principal - Single Page con todas las secciones
import Layout from '../layouts/Layout.astro'
---

<Layout title="XV Años Ana Valeria">
	<main>
		<!-- Las secciones se irán agregando aquí -->
		<section class="min-h-screen flex items-center justify-center bg-primary-50">
			<div class="text-center">
				<h1 class="font-serif text-5xl md:text-7xl text-primary-800">
					Ana Valeria
				</h1>
				<p class="font-display text-sm tracking-[0.3em] text-gold-500 mt-4 uppercase">
					Mis Quince Años
				</p>
				<p class="text-primary-600 mt-6 font-sans">
					16 de Mayo de 2026
				</p>
			</div>
		</section>
	</main>
</Layout>
